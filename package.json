{
  "name": "flowcube",
  "private": true,
  "description": "仓库根脚本（tag / 工具），业务包见 frontend、desktop、backend",
  "scripts": {
    "pretag": "bash scripts/git-tag-check.sh",
    "release:tag-desktop": "bash scripts/release-desktop-tag.sh",
    "release:prod": "bash scripts/release-prod.sh",
    "release:gate": "bash scripts/release-gate.sh",
    "release:check-downloads": "node scripts/check-deprecated-downloads.js",
    "deploy:keygen": "bash scripts/setup-deploy-key.sh",
    "smoke:concurrency-guards": "node tests/concurrency-guards.smoke.test.js",
    "smoke:mainline": "node tests/mainline.smoke.test.js",
    "smoke:reports": "npm --prefix backend run smoke:reports",
    "smoke:pages": "bash scripts/smoke-pages.sh",
    "smoke:reconciliation": "bash scripts/smoke-reconciliation-jumps.sh"
  }
}
