# 服务配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=flowcube
DB_PASSWORD=replace_with_local_password
DB_NAME=flowcube

# JWT 配置
JWT_SECRET=replace_with_a_random_string_at_least_32_chars_long
JWT_EXPIRES_IN=7d

# 首次启用管理员账号时，可配合 `npm run bootstrap:admin` 使用
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_REAL_NAME=系统管理员

# 登录限流（POST /api/auth/login，按 IP；反代后请设 TRUST_PROXY=1）
# AUTH_LOGIN_MAX_PER_IP=300
# AUTH_LOGIN_WINDOW_MS=900000

# CORS 配置
CORS_ORIGIN=http://localhost:5173
# Electron 桌面请求 Origin 多为 null。生产环境请任选其一：
# CORS_REFLECT=1
# CORS_ALLOW_NULL_ORIGIN=1
# CORS_ORIGIN=*
# 开发环境默认允许 null（除非 CORS_ALLOW_NULL_ORIGIN=0）

# 桌面端更新（0.3.5 等旧版只会用接口返回的 url 下载；须同域 HTTPS + 服务器上已有 exe）
# APP_PUBLIC_URL=https://your-domain.com   # 生产环境必填；缺失时后端会直接拒绝启动，避免更新链半残运行
# TRUST_PROXY=1                            # 前面有 Nginx/反代时建议开启，否则下载链接可能错成 http://
# APP_UPDATE_USE_GITHUB_DIRECT_URL=        # 设为 1 时仍返回 GitHub 直链（境内一般不要开）
# APP_UPDATE_DOWNLOADS_DIR=/var/www/flowcube-downloads
# APP_UPDATE_MANIFEST_PATH=        # 默认 ${APP_UPDATE_DOWNLOADS_DIR}/latest.json

# 仅排障：500 时在接口 message 中返回真实异常（勿长期对公网开启）
# APP_EXPOSE_ERRORS=1

# 入库逐包收货后打印容器标签（可选）：
# - 填写时：与「打印机管理」中的编码 code 一致
# - 不填：自动选用第一台在线且类型为「标签打印机」的记录
# INBOUND_LABEL_PRINTER_CODE=

# ── 本地脚本 tests/integration.test.js、tests/concurrency.stress.test.js（勿把密码写入仓库）──
# TEST_DB_PASSWORD=
# TEST_DB_HOST=127.0.0.1
# TEST_DB_USER=flowcube
# TEST_DB_NAME=flowcube
# TEST_API_HOST=localhost
# TEST_API_PORT=3000
