# 服务配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=flowcube

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# 桌面端更新：对外访问的根地址（清单里只有 filename 时用于拼接下载 URL）
# APP_PUBLIC_URL=https://your-domain.com
# APP_UPDATE_MANIFEST_PATH=        # 默认 backend/downloads/latest.json
# APP_UPDATE_DOWNLOADS_DIR=        # 默认 backend/downloads

# 入库逐包收货后打印容器标签（可选）：
# - 填写时：与「打印机管理」中的编码 code 一致
# - 不填：自动选用第一台在线且类型为「标签打印机」的记录
# INBOUND_LABEL_PRINTER_CODE=
