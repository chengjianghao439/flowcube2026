{
  "name": "flowcube-frontend",
  "private": true,
  "version": "0.3.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "cross-env VITE_ELECTRON=1 vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "build:pda": "cross-env VITE_CAPACITOR=1 vite build",
