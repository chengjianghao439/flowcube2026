# FlowCube 根目录 Docker / 部署环境样例
# 使用方式：
#   cp .env.example .env
#   按需修改后再执行 docker compose up -d

# MySQL 容器与后端共享的数据库配置
MYSQL_ROOT_PASSWORD=replace_with_local_root_password
DB_NAME=flowcube
DB_USER=flowcube
DB_PASSWORD=replace_with_local_app_password
MYSQL_PORT=3306

# 后端运行配置
PORT=3000
DB_HOST=mysql
DB_PORT=3306
JWT_SECRET=replace_with_a_random_string_at_least_32_chars_long
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
CORS_REFLECT=0
CORS_ALLOW_NULL_ORIGIN=0
TRUST_PROXY=0
APP_PUBLIC_URL=                     # 生产环境必填；缺失时后端会直接拒绝启动
APP_UPDATE_DOWNLOADS_DIR=/var/www/flowcube-downloads
FLOWCUBE_DOWNLOADS_DIR=/var/www/flowcube-downloads

# 烟雾脚本账号仅在需要运行发布门禁时设置，勿提交真实值
SMOKE_USERNAME=
SMOKE_PASSWORD=

# 首次启用管理员账号时，可配合 `npm --prefix backend run bootstrap:admin` 使用
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_REAL_NAME=系统管理员

# 桌面/PDA 构建环境变量（按需导出给前端构建命令）
# VITE_ERP_PRODUCTION_ORIGIN=        # build-time default；runtime override 统一使用 API_BASE_URL
# VITE_PDA_FALLBACK_API_ORIGIN=
