# 复制为项目根目录的 `.env` 后执行 `docker compose up -d`
# cp deploy.example.env .env && nano .env

# ── 必改（生产）────────────────────────────────────────
DB_PASSWORD=请换成强密码
# 须 ≥32 字符；切勿使用仓库内默认值上线
JWT_SECRET=请用 openssl rand -hex 32 生成并粘贴到这里

# 浏览器访问前端的完整 Origin（协议+域名+端口，无尾斜杠）
# 例：http://43.x.x.x 或 https://erp.example.com
CORS_ORIGIN=http://127.0.0.1

# ── 可选 ────────────────────────────────────────────────
DB_USER=flowcube
DB_NAME=flowcube

# 前面还有一层 HTTPS 反代时建议 1，便于生成正确的安装包下载链接
TRUST_PROXY=1

# 与对外访问域名一致时填写，例如 https://erp.example.com
APP_PUBLIC_URL=

# 生产建议 NODE_ENV 由 compose 传入 production（已写死）
