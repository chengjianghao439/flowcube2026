{
  "name": "flowcube-desktop",
  "version": "1.0.0",
  "description": "FlowCube ERP 桌面端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.flowcube.erp",
    "productName": "FlowCube ERP",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "../dist-electron"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "files": ["main.js", "../backend/**/*", "!../backend/node_modules"],
    "extraResources": [{ "from": "../backend", "to": "backend", "filter": ["**/*", "!node_modules/**"] }]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
